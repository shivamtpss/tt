{
  "name": "shivam-guide",
  "version": "2.0.0",
  "description": "ShivamGuide — drop-in Live2D onboarding tour (spotlight, dialogue, poses) for any website or React/Next app.",
  "license": "MIT",
  "type": "module",
  "main": "./shivam-guide.js",
  "module": "./shivam-guide.js",
  "types": "./shivam-guide.d.ts",
